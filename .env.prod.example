# Copy this file to .env.prod on the server and fill in real values.
# docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build

# Shared secret required to trigger POST /scrape from the internet.
# Generate one with: openssl rand -hex 24
SCRAPE_SECRET=

# How often (in hours) the API automatically scrapes and stores a new price
# snapshot, on top of any manually triggered scrapes. Defaults to 24 if unset.
HOURS_BETWEEN_FETCH=24

# Token of the Telegram bot used by the `notifier` service.
# Get one from @BotFather on Telegram.
TELEGRAM_BOT_TOKEN=
